{
  "name": "@household-finance/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && mkdir -p dist/modules/payslip/llm-extract && cp src/modules/payslip/llm-extract/payslip.schema.json dist/modules/payslip/llm-extract/",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "test": "bash -c 'export MODE=TEST; bash ../scripts/prep-test-db.sh && bash ../scripts/db.sh --init --seed --dev-seeds && vitest run'",
    "extract-payslip-llm": "tsx scripts/extract-payslip-llm.ts"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "openai": "^4.77.0",
    "pdf-parse": "^1.1.1",
    "postgres": "^3.4.8",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.8.1",
    "@types/pdf-parse": "^1.1.4",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.12.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
