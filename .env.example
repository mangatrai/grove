PORT=4000
FRONTEND_PORT=3000
# Backend only: minimum log level (debug | info | warn | error | silent). Default info.
LOG_LEVEL=info
# Optional: also append logs to this file (repo-relative or absolute). Tee with console; parent dirs created.
# LOG_FILE=.runtime/logs/app.log
MODE=TEST
# Generate a strong secret: openssl rand -base64 48
# Must be ≥ 32 characters. The app will refuse to start in PROD with the default value.
JWT_SECRET=replace-with-long-random-secret-min-32-chars

# PROD: restrict CORS to your app's public URL (e.g. https://finance.example.com).
# Leave unset in TEST/dev — all origins are allowed.
# ALLOWED_ORIGIN=https://finance.example.com

# Postgres (required). Local Docker: `docker compose up -d` then e.g.:
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5433
# DATABASE_USER=household
# DATABASE_PASSWORD=household
# DATABASE_NAME=household_finance_test
# DATABASE_SSL=0
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=
# Set 0 / false for local Postgres without TLS (e.g. docker-compose on localhost).
DATABASE_SSL=1

# Frontend (Vite): optional dev sign-in prefill on `/`. Leave empty for blank fields. Production builds should leave these unset.
VITE_DEV_SIGNIN_EMAIL=
VITE_DEV_SIGNIN_PASSWORD=
# API origin for the Vite dev proxy (defaults to http://127.0.0.1:4000 if unset).
# VITE_PROXY_API=http://127.0.0.1:4000

# Transfer matcher (backend).
TRANSFER_MIN_AUTO_PAIR_SCORE=45
TRANSFER_DISAMBIG_STRONG_MIN_SCORE=70
TRANSFER_DISAMBIG_STRONG_GAP=20
TRANSFER_DISAMBIG_WEAK_MIN_SCORE=45
TRANSFER_DISAMBIG_WEAK_MAX_SECOND_SCORE=25

# OpenAI — required for Deloitte payslip import (async LLM extract). Optional for other features.
# Recommended: gpt-4.1 (best instruction-following for complex Deloitte multi-column layout).
# gpt-4.1-mini and gpt-4o-mini have known issues with column-type disambiguation on Deloitte stubs.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
LLM_PROVIDER=openai
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o-mini   # cheaper but lower accuracy on Deloitte multi-column stubs
# Min ms between background polls for queued Deloitte LLM extraction (default 120000).
# PAYSLIP_ASYNC_POLL_INTERVAL_MS=120000

# Email / SMTP (optional, required for self-service password reset and invite flows)
SMTP_HOST=
SMTP_PORT=587
# 0 for STARTTLS on 587, 1 for SSL on 465.
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
# Example: Household Finance <you@gmail.com>
SMTP_FROM=
# Public base URL used in password-reset links and OAuth callbacks.
# Example: https://finance.example.com
PUBLIC_BASE_URL=
#
# Provider examples:
# Resend (SMTP relay)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=1
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxx
# SMTP_FROM=Household Finance <onboarding@resend.dev>
#
# Gmail App Password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=yourname@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM=Household Finance <yourname@gmail.com>

# Cash summary: max inclusive days for custom dateFrom/dateTo on GET /reports/cash-summary (default 1096).
# CASH_SUMMARY_MAX_CUSTOM_RANGE_DAYS=1096