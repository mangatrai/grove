PORT=4000
FRONTEND_PORT=3000
# Process timezone — anchors new Date() locale methods and log timestamps.
# Set this in Koyeb env vars and locally in .env. Does not affect UTC-based DB timestamps.
TZ=America/Chicago
# Backend only: minimum log level (debug | info | warn | error | silent). Default info.
LOG_LEVEL=info
# Optional: also append logs to this file (repo-relative or absolute). Tee with console; parent dirs created.
# LOG_FILE=.runtime/logs/app.log
MODE=TEST

# Generate a strong secret: openssl rand -base64 48
# Must be ≥ 32 characters. The app will refuse to start in PROD with the default value.
JWT_SECRET=replace-with-long-random-secret-min-32-chars

# Optional backup encryption key (exactly 64 hex chars = 32 bytes).
# If set, exported .hfb backups are AES-256-GCM encrypted and require this same key for restore.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKUP_ENCRYPTION_KEY=

# PROD: restrict CORS to your app's public URL (e.g. https://finance.example.com).
# Leave unset in TEST/dev — all origins are allowed.
# ALLOWED_ORIGIN=https://finance.example.com

# Postgres (required). Local Docker: `docker compose up -d` then e.g.:
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5433
# DATABASE_USER=household
# DATABASE_PASSWORD=household
# DATABASE_NAME=household_finance_test
# DATABASE_SSL=0
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=
# Set 0 / false for local Postgres without TLS (e.g. docker-compose on localhost).
DATABASE_SSL=1

# Frontend (Vite): optional dev sign-in prefill on `/`. Leave empty for blank fields. Production builds should leave these unset.
VITE_DEV_SIGNIN_EMAIL=
VITE_DEV_SIGNIN_PASSWORD=
# API origin for the Vite dev proxy (defaults to http://127.0.0.1:4000 if unset).
# VITE_PROXY_API=http://127.0.0.1:4000

# Transfer matcher (backend).
TRANSFER_MIN_AUTO_PAIR_SCORE=45
TRANSFER_DISAMBIG_STRONG_MIN_SCORE=70
TRANSFER_DISAMBIG_STRONG_GAP=20
TRANSFER_DISAMBIG_WEAK_MIN_SCORE=45
TRANSFER_DISAMBIG_WEAK_MAX_SECOND_SCORE=25

# LLM provider selection — controls which provider is used for chat, tool-use, and vision (payslip/OCR).
# Set LLM_PROVIDER=anthropic to use Anthropic Claude; set LLM_PROVIDER=openai (default) to use OpenAI.
LLM_PROVIDER=openai

# OpenAI — required when LLM_PROVIDER=openai.
# OPENAI_MODEL: payslip vision extraction + insights + summarization. gpt-4.1-mini is the recommended
#   cost-effective choice. gpt-4o-mini has known issues with Deloitte multi-column stubs; gpt-4.1-mini works.
# OPENAI_STRONG_MODEL: protest chat tool-use loop + ARB hearing script. Needs a capable model.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_STRONG_MODEL=gpt-4o

# Anthropic — required when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_STRONG_MODEL=claude-sonnet-4-6

# Embedding provider — controls which provider is used for pgvector RAG embeddings (protest document store).
# Only "openai" is supported currently. Independent of LLM_PROVIDER.
EMBEDDING_PROVIDER=openai

# pgvector RAG — protest document store (PT-3).
# EMBEDDING_MODEL defaults to text-embedding-3-small (1536 dims).
# Changing EMBEDDING_MODEL requires a new DB migration (vector column size) and full re-embed.
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_MAX_INPUT_CHARS=8000
# RAG_TOP_K=5
# RAG_MIN_SIMILARITY=0.65

# RealtyAPI — property valuation via Redfin (D-2). Optional; feature degrades to manual if absent.
# Free tier: 250 req/month — sufficient for ~10 properties refreshed monthly + on-demand calls.
# Sign up: https://www.realtyapi.io/
REALTY_API_KEY=

# Min ms between background polls for queued Deloitte LLM extraction (default 120000).
# PAYSLIP_ASYNC_POLL_INTERVAL_MS=120000

# Email / SMTP (optional, required for self-service password reset and invite flows)
SMTP_HOST=
SMTP_PORT=587
# 0 for STARTTLS on 587, 1 for SSL on 465.
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
# Example: Household Finance <you@gmail.com>
SMTP_FROM=
# Public base URL used in password-reset links and (if FRONTEND_APP_URL unset) post–Google-Drive OAuth redirect to the SPA (/#/settings?...).
# Example: https://finance.example.com
PUBLIC_BASE_URL=

# SPA origin when the API runs on a different host/port than the UI (e.g. http://localhost:3000 for Vite while API is on :4000).
# If unset: uses PUBLIC_BASE_URL when set; in MODE=TEST defaults to http://localhost:3000 for GDrive OAuth return only.
# FRONTEND_APP_URL=http://localhost:3000

# Google Drive — OAuth2 Web client (optional; required for Settings → Data → Google Drive connect).
# Redirect URI must match Google Cloud Console exactly (path /gdrive/oauth/callback on your API host).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://127.0.0.1:4000/gdrive/oauth/callback
#
# Provider examples:
# Resend (SMTP relay)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=1
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxx
# SMTP_FROM=Household Finance <onboarding@resend.dev>
#
# Gmail App Password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=yourname@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM=Household Finance <yourname@gmail.com>

# Cash summary: max inclusive days for custom dateFrom/dateTo on GET /reports/cash-summary (default 1096).
# CASH_SUMMARY_MAX_CUSTOM_RANGE_DAYS=1096

# Google OAuth2 (Drive) — optional; required for GDrive connect / backup when using user-delegated auth.
GOOGLE_CLIENT_ID=123456789-abc123.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://<ip-address>:<port>/gdrive/oauth/callback

FRONTEND_APP_URL=http://<ip-address>:<port>

TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxx