PORT=4000
FRONTEND_PORT=3000
# Backend only: minimum log level (debug | info | warn | error | silent). Default info.
LOG_LEVEL=info
# Optional: also append logs to this file (repo-relative or absolute). Tee with console; parent dirs created.
# LOG_FILE=.runtime/logs/app.log
MODE=TEST
DB_PATH=
DB_PATH_TEST=./data/household-finance-test.sqlite
DB_PATH_PROD=./data/household-finance-prod.sqlite
JWT_SECRET=replace-with-long-random-secret

# Frontend (Vite): optional dev sign-in prefill on `/`. Leave empty for blank fields. Production builds should leave these unset.
VITE_DEV_SIGNIN_EMAIL=
VITE_DEV_SIGNIN_PASSWORD=
# API origin for the Vite dev proxy (defaults to http://127.0.0.1:4000 if unset).
# VITE_PROXY_API=http://127.0.0.1:4000

# Transfer matcher (backend).
TRANSFER_MIN_AUTO_PAIR_SCORE=45
TRANSFER_DISAMBIG_STRONG_MIN_SCORE=70
TRANSFER_DISAMBIG_STRONG_GAP=20
TRANSFER_DISAMBIG_WEAK_MIN_SCORE=45
TRANSFER_DISAMBIG_WEAK_MAX_SECOND_SCORE=25

# Postgres (reserved; app uses SQLite today).
DATABASE_HOST=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=

# OpenAI (optional; AI categorization is off unless enabled below)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Set to 1/true to run LLM categorization after deterministic rules (requires OPENAI_API_KEY).
AI_CATEGORY_ENABLED=0
# Confidence 0–1: auto-apply category when at or above this (default 0.9). Try 0.7–0.75 for fewer reviews (more mislabels).
AI_CATEGORY_AUTO_APPLY_MIN=0.9
# Minimum confidence to store a suggestion in review payload reason JSON (default 0.6).
AI_CATEGORY_REVIEW_MIN=0.6
# Transactions per OpenAI request when batching (default 28; max 128).
AI_CATEGORY_BATCH_SIZE=28
# Concurrent OpenAI HTTP requests per contiguous AI run (1–8). Default 1; raise cautiously (429 rate limits).
AI_CATEGORY_MAX_PARALLEL=1
# When LOG_LEVEL=debug, max chars logged per OpenAI request/response body snippet (default 4000).
# LOG_AI_DEBUG_BODY_MAX_CHARS=4000